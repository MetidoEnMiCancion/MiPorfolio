---
import AstroIcon from '../components/Iconos/Astro1.astro';
import TailwindIcon from '../components/Iconos/Tailwind.astro';
import HTMLIcon from '../components/Iconos/HTML.astro';
import CssIcon from '../components/Iconos/Css.astro';
// Props que podés pasar para personalizar el componente
const {
  titulo = "Sobre Mí",
  nombre = "Centeno Fernando Gabriel",
  descripcion1 = "Soy un desarrollador web apasionado por la tecnología, la creatividad y el aprendizaje continuo. Nací el 7 de octubre de 1991 en Buenos Aires, Argentina, y actualmente resido en Virrey del Pino, La Matanza.",
  descripcion2 = "Me especializo en crear soluciones digitales modernas, funcionales y atractivas, enfocadas en ofrecer una excelente experiencia de usuario. Disfruto trabajar en proyectos desafiantes que me permitan seguir creciendo profesionalmente y perfeccionando mis habilidades.Si buscas un desarrollador comprometido, responsable y entusiasta, estaré encantado de ayudarte a convertir tus ideas en realidad.",
  imagen = "../Yo1.jpeg",
} = Astro.props;
---

<section id="sobreMi" class="relative w-full px-6 py-16 bg-gradient-to-tr text-white">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-10 items-center relative z-10">

    <!-- Texto -->
    <div>
      <div class="inline-block px-6 py-2 rounded-full bg-gradient-to-r from-purple-500 to-indigo-500 text-white font-semibold text-lg mb-6 shadow-lg">
        {titulo}
      </div>

      <h2 class="text-2xl font-semibold mb-4 text-yellow-200/70">{nombre}</h2>

      <p class="text-lg text-gray-400 mb-4">{descripcion1}</p>
      <p class="text-lg text-gray-400 mb-6">{descripcion2}</p>
     <div class="flex flex-col items-start gap-4">

  <h1 class="text-lg font-bold">Tecnologías que utilizo</h1>

  <div class="flex gap-6">
    <div class="flex flex-col items-center">
      <CssIcon class="size-12 md:size-11" />
      <span class="mt-2 text-sm">CSS</span>
    </div>
    <div class="flex flex-col items-center">
      <HTMLIcon class="size-12 md:size-11" />
      <span class="mt-2 text-sm">HTML</span>
    </div>
    <div class="flex flex-col items-center">
      <AstroIcon class="size-12 md:size-11" />
      <span class="mt-2 text-sm">Astro</span>
    </div>
    <div class="flex flex-col items-center">
      <TailwindIcon class="size-12 md:size-11" />
      <span class="mt-2 text-sm">TailwindCSS</span>
    </div>
  </div>
</div>
    </div>

    <!-- Imagen -->
    <div class="relative flex justify-center">
      <div class="relative z-10 rounded-[30%] overflow-hidden shadow-2xl ring-4 border-yellow-200">
        <img src={imagen} alt="Foto personal" class="w-64 h-80 object-cover rounded-[30%]" />
      </div>

      <!-- Fondo detrás de la imagen -->
      <div class="absolute -top-5 -right-5 w-64 h-80 rounded-[30%] bg-yellow-200/10 blur-2xl z-0"></div>
    </div>

  </div>
</section>
